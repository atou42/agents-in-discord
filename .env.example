# Minimal project config.
# Only keep Discord/runtime settings here.
# CLI login/auth is managed by your local `codex` / `claude` / `agy` / `zcode`, not by this file.
# Everything else falls back to in-code defaults; add extra keys only when you really need an override.

# ============================================================
# Shared
# ============================================================

# Restrict bot access. Leave empty to allow all.
ALLOWED_CHANNEL_IDS=
ALLOWED_GUILD_IDS=
ALLOWED_USER_IDS=
# MENTION_ONLY_CHANNEL_IDS=

# Legacy fallback root for auto-created thread workspaces.
WORKSPACE_ROOT=./workspaces

# Optional shared default workspace for all providers.
# DEFAULT_WORKSPACE_DIR=~/GitHub

# Child thread workspace mode:
# - inherit: reuse the parent channel's explicit workspace
# - separate: use the child thread's own default/fallback workspace instead
# CHILD_THREAD_WORKSPACE_MODE=inherit

# Default UI language for bot hints: zh | en
DEFAULT_UI_LANGUAGE=zh

# Extra info sent to the runner with each Discord prompt.
# EXTRA_INFO_ENABLED=true
# EXTRA_INFO_TEXT=[Via agents-in-discord; discord_thread={thread}; parent={parent}]

# agents-in-discord project update checks:
# - notify is the default: check remote updates and show prompts without changing files
# - auto only upgrades when the git worktree is clean and the remote update is a fast-forward
# AGENTS_IN_DISCORD_UPGRADE_MODE=notify
# AGENTS_IN_DISCORD_UPGRADE_ADMIN_USER_IDS=
# AGENTS_IN_DISCORD_UPGRADE_NOTIFY_CHANNEL_IDS=
# AGENTS_IN_DISCORD_UPGRADE_CHECK_INTERVAL_MS=21600000
# AGENTS_IN_DISCORD_UPGRADE_STATUS_CACHE_MS=600000
# AGENTS_IN_DISCORD_UPGRADE_VERIFY_COMMAND=npm run test:progress
# AGENTS_IN_DISCORD_UPGRADE_RESTART_TARGET=all

# Force mention-only in selected guilds. Comma-separated guild IDs.
# MENTION_ONLY_ENABLED_GUILD_IDS=
# MENTION_ONLY_DISABLED_GUILD_IDS=

# Shared slash prefix (used mainly in shared mode).
# Dedicated bots default to cx (codex) / cc (claude) / ag (antigravity) / zc (zcode) unless overridden below.
# SLASH_PREFIX=cx

# Optional proxy.
HTTP_PROXY=
HTTPS_PROXY=
SOCKS_PROXY=
ALL_PROXY=
INSECURE_TLS=0

# ============================================================
# Shared mode (single bot, optional)
# ============================================================

# DISCORD_TOKEN=
# DEFAULT_PROVIDER=codex

# ============================================================
# Codex Bot
# Loaded automatically by `npm run start:codex`
# ============================================================

CODEX__DISCORD_TOKEN=
# CODEX__ALLOWED_CHANNEL_IDS=
# CODEX__ALLOWED_GUILD_IDS=
# CODEX__ALLOWED_USER_IDS=
# CODEX__MENTION_ONLY_CHANNEL_IDS=
# CODEX__DEFAULT_MODEL=
CODEX__DEFAULT_MODE=dangerous
# CODEX__COMPACT_STRATEGY=native
# CODEX__MAX_INPUT_TOKENS_BEFORE_COMPACT=250000
# CODEX__SLASH_PREFIX=cx
# CODEX__CODEX_BIN=codex
# CODEX__RUNTIME_MODE=normal
# CODEX__APP_SERVER_IDLE_MS=900000
# CODEX__APP_SERVER_MAX_SESSIONS=8
# CODEX__DEFAULT_WORKSPACE_DIR=~/GitHub

# ============================================================
# Claude Bot
# Loaded automatically by `npm run start:claude`
# ============================================================

CLAUDE__DISCORD_TOKEN=
# CLAUDE__ALLOWED_CHANNEL_IDS=
# CLAUDE__ALLOWED_GUILD_IDS=
# CLAUDE__ALLOWED_USER_IDS=
# CLAUDE__MENTION_ONLY_CHANNEL_IDS=
# CLAUDE__DEFAULT_MODEL=
CLAUDE__DEFAULT_MODE=dangerous
CLAUDE__RUNTIME_MODE=normal
# CLAUDE__SLASH_PREFIX=cc
# CLAUDE__CLAUDE_BIN=claude
# CLAUDE__DEFAULT_WORKSPACE_DIR=~/GitHub

# ============================================================
# Antigravity Bot
# Loaded automatically by `npm run start:antigravity`
# ============================================================

ANTIGRAVITY__DISCORD_TOKEN=
# ANTIGRAVITY__ALLOWED_CHANNEL_IDS=
# ANTIGRAVITY__ALLOWED_GUILD_IDS=
# ANTIGRAVITY__ALLOWED_USER_IDS=
# ANTIGRAVITY__MENTION_ONLY_CHANNEL_IDS=
ANTIGRAVITY__DEFAULT_MODE=dangerous
# ANTIGRAVITY__SLASH_PREFIX=ag
ANTIGRAVITY_BIN=agy
# ANTIGRAVITY__DEFAULT_WORKSPACE_DIR=~/GitHub

# ============================================================
# ZCode Bot
# Loaded automatically by `npm run start:zcode`
# ============================================================

ZCODE__DISCORD_TOKEN=
# ZCODE__ALLOWED_CHANNEL_IDS=
# ZCODE__ALLOWED_GUILD_IDS=
# ZCODE__ALLOWED_USER_IDS=
# ZCODE__MENTION_ONLY_CHANNEL_IDS=
ZCODE__DEFAULT_MODE=dangerous
# ZCODE__SLASH_PREFIX=zc
ZCODE_BIN=zcode
# ZCODE__DEFAULT_WORKSPACE_DIR=~/GitHub

# Legacy fallback (older single-file naming, still supported):
# DISCORD_TOKEN_CODEX=
# DISCORD_TOKEN_CLAUDE=
# DISCORD_TOKEN_ZCODE=
